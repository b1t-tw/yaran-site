---
import '../styles/main.css';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const fullTitle = `${title} - YARAN 野蘭攝影棚`;
const description = 'YARAN 野蘭攝影棚';
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/logo_icon.png" />
    <title>{fullTitle}</title>
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Chiron+Sung+HK:ital,wght@0,200..900;1,200..900&family=Cinzel:wght@400..900&0&family=Cormorant+Infant:ital,wght@0,300..700;1,300..700&display=swap" rel="stylesheet">
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Q3919S3X7X"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-Q3919S3X7X');
    </script>
    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-5CPDV3HJ');
    </script>
    <!-- End Google Tag Manager -->
    <!-- Meta Pixel Code -->
    <script is:inline>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '2839746599700251');
      fbq('track', 'PageView');
    </script>
    <!-- Track frametime.app clicks as InitiateCheckout -->
    <script is:inline>
      document.addEventListener('click', function (e) {
        var a = e.target.closest('a[href*="frametime.app"]');
        if (!a) return;

        // Collect utm_* params from the current page URL
        var pageParams = new URLSearchParams(window.location.search);
        var utm = {};
        pageParams.forEach(function (value, key) {
          if (key.indexOf('utm_') === 0) utm[key] = value;
        });

        // Append them to the frametime destination URL (without overwriting existing ones)
        try {
          var dest = new URL(a.href, window.location.origin);
          Object.keys(utm).forEach(function (key) {
            if (!dest.searchParams.has(key)) dest.searchParams.set(key, utm[key]);
          });
          a.href = dest.toString();
        } catch (err) {}

        if (window.fbq) fbq('track', 'InitiateCheckout', utm);
      });
    </script>
    <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=2839746599700251&ev=PageView&noscript=1"
    /></noscript>
    <!-- End Meta Pixel Code -->
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5CPDV3HJ"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    {
      title !== '首頁' && (
        <Header/>
        <div class="text-center border-b border-[#fff3]">
          <h1 class="py-8">{title}</h1>
          <div class="text-primary-light">
            <slot name="subtitle" />
          </div>
        </div>
      )
    }
    <slot />
    <Footer />
  </body>
</html>
