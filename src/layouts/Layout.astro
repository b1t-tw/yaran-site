---
import '../styles/main.css';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const fullTitle = `${title} - YARAN 野蘭攝影棚`;
const description = 'YARAN 野蘭攝影棚';

// 背景圖樣清單（放在 public/patterns/），每次載入隨機挑一張
const patterns = Object.keys(import.meta.glob('/public/patterns/*.png')).map(
  (path) => path.replace('/public', '')
);
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/logo_icon.png" />
    <script is:inline define:vars={{ patterns }}>
      // 每次載入隨機選一張背景圖樣，設定給 body::before 使用
      // 換頁時排除上一張，確保一定會換成不同的圖樣
      if (patterns.length) {
        const last = sessionStorage.getItem('background-pattern');
        const candidates = patterns.filter((p) => p !== last);
        const pool = candidates.length ? candidates : patterns;
        const pick = pool[Math.floor(Math.random() * pool.length)];
        sessionStorage.setItem('background-pattern', pick);
        document.documentElement.style.setProperty(
          '--background-pattern',
          `url("${pick}")`
        );
      }
    </script>
    <title>{fullTitle}</title>
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Chiron+Sung+HK:ital,wght@0,200..900;1,200..900&family=Cinzel:wght@400..900&0&family=Cormorant+Infant:ital,wght@0,300..700;1,300..700&display=swap" rel="stylesheet">
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Q3919S3X7X"></script>
    <script is:inline>
import { swapBodyElement } from "astro/virtual-modules/transitions-swap-functions.js";

      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-Q3919S3X7X');
    </script>
    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-5CPDV3HJ');
    </script>
    <!-- End Google Tag Manager -->
    <!-- Meta Pixel Code -->
    <script is:inline>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '2839746599700251');
      fbq('track', 'PageView');
    </script>
    <!-- Track frametime.app clicks as InitiateCheckout -->
    <script is:inline>
      document.addEventListener('click', function (e) {
        var a = e.target.closest('a[href*="frametime.app"]');
        if (!a) return;

        // Read the original ad attribution from the current page URL
        var pageParams = new URLSearchParams(window.location.search);
        var src = pageParams.get('utm_source');
        var medium = pageParams.get('utm_medium');
        var campaign = pageParams.get('utm_campaign');

        // Frametime is our referrer: identify our site as the source, keep the
        // campaign, and preserve the original ad attribution under namespaced keys.
        var handoff = {
          utm_source: 'yaran-site',
          utm_medium: 'referral',
        };
        if (campaign) handoff.utm_campaign = campaign;
        if (src) handoff.yaran_src = src;
        if (medium) handoff.yaran_medium = medium;

        // Append to the frametime destination URL (without overwriting existing params)
        try {
          var dest = new URL(a.href, window.location.origin);
          Object.keys(handoff).forEach(function (key) {
            if (!dest.searchParams.has(key)) dest.searchParams.set(key, handoff[key]);
          });
          a.href = dest.toString();
        } catch (err) {}

        if (window.fbq) fbq('track', 'InitiateCheckout', handoff);
      });
    </script>
    <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=2839746599700251&ev=PageView&noscript=1"
    /></noscript>
    <!-- End Meta Pixel Code -->
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5CPDV3HJ"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    {
      title !== '首頁' && (
        <Header/>
        <slot name="subheader" />
        <div class="text-center border-b border-[#fff3]">
          <h1 class="py-8">{title}</h1>
          <div class="text-primary-light">
            <slot name="subtitle" />
          </div>
        </div>
      )
    }
    <slot />
    <Footer />
  </body>
</html>
