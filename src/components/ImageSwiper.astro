---
import { Image } from "astro:assets";
import { loadGalleryItems } from "../lib/gallery";

interface Props {
  /** 相對於 src/assets/images 的資料夾名稱，例如 "tea-shop" */
  dir: string;
  /** 圖片 alt 前綴，預設用 dir */
  alt?: string;
  class?: string;
}

const { dir, alt, class: className } = Astro.props;

const items = await loadGalleryItems(dir);
---

{
  items.length > 0 && (
    <div class:list={["gallery-swiper swiper", className]}>
      <div class="swiper-wrapper">
        {items.map((item, i) => (
          <div
            class="swiper-slide"
            data-pswp-src={item.full.src}
            data-pswp-width={item.full.attributes.width}
            data-pswp-height={item.full.attributes.height}>
            <Image
              src={item.thumb}
              alt={`${alt ?? dir} ${i + 1}`}
              format="webp"
              quality={80}
              width={800}
              height={800}
              loading={i === 0 ? "eager" : "lazy"}
              class="h-full w-full object-contain cursor-zoom-in"
            />
          </div>
        ))}
      </div>
      <div class="swiper-pagination" />
    </div>
  )
}

<script>
  import Swiper from "swiper";
  import { Autoplay, Pagination, Keyboard, A11y } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/pagination";
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import "photoswipe/style.css";
  import { enhanceLightbox } from "../lib/lightbox";

  // 頁面上每個 .gallery-swiper 各自初始化（支援多個 instance）
  document.querySelectorAll<HTMLElement>(".gallery-swiper").forEach((el) => {
    const swiper = new Swiper(el, {
      modules: [Autoplay, Pagination, Keyboard, A11y],
      loop: true,
      spaceBetween: 16,
      autoplay: {
        delay: 3000,
        disableOnInteraction: false,
      },
      keyboard: { enabled: true },
      pagination: { el: el.querySelector(".swiper-pagination"), clickable: true },
    });

    // 依原始 slide（排除 loop 複製）順序建立燈箱資料
    const dataSource = Array.from(
      el.querySelectorAll<HTMLElement>(".swiper-slide:not(.swiper-slide-duplicate)"),
    ).map((slide) => ({
      src: slide.dataset.pswpSrc!,
      width: Number(slide.dataset.pswpWidth),
      height: Number(slide.dataset.pswpHeight),
    }));

    const lightbox = new PhotoSwipeLightbox({
      dataSource,
      pswpModule: () => import("photoswipe"),
    });
    enhanceLightbox(lightbox);
    lightbox.init();

    // 點擊（非拖曳）開啟燈箱；用 realIndex 對應原始圖片順序
    swiper.on("click", () => {
      const slide = swiper.clickedSlide;
      if (!slide) return;
      const realIndex = Number(slide.getAttribute("data-swiper-slide-index") ?? swiper.clickedIndex);
      lightbox.loadAndOpen(realIndex);
    });

    // 燈箱開啟時暫停自動輪播，關閉後恢復
    lightbox.on("beforeOpen", () => swiper.autoplay.stop());
    lightbox.on("close", () => swiper.autoplay.start());
  });
</script>

<style>
  .gallery-swiper {
    width: 100%;
    aspect-ratio: 3 / 2;
    border-radius: 0.5rem;
    overflow: hidden;
    --swiper-theme-color: rgba(255, 255, 255, 0.8);
    --swiper-pagination-bullet-inactive-color: rgba(255, 255, 255, 1);
  }
</style>
