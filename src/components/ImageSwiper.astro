---
import { Image } from "astro:assets";

interface Props {
  /** 相對於 src/assets/images 的資料夾名稱，例如 "tea-shop" */
  dir: string;
  /** 圖片 alt 前綴，預設用 dir */
  alt?: string;
  class?: string;
}

const { dir, alt, class: className } = Astro.props;

// glob 的 pattern 必須是字串字面值，所以掃整個 images 後再依 dir 過濾
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/**/*.{jpg,jpeg,png,webp,avif,JPG,JPEG,PNG}",
  { eager: true },
);

const prefix = `/src/assets/images/${dir.replace(/^\/|\/$/g, "")}/`;
const images = Object.entries(allImages)
  .filter(([path]) => path.startsWith(prefix))
  .sort(([a], [b]) => a.localeCompare(b, undefined, { numeric: true }))
  .map(([, mod]) => mod.default);
---

{
  images.length > 0 && (
    <div class:list={["gallery-swiper swiper", className]}>
      <div class="swiper-wrapper">
        {images.map((img, i) => (
          <div class="swiper-slide">
            <Image
              src={img}
              alt={`${alt ?? dir} ${i + 1}`}
              format="webp"
              quality={80}
              width={720}
              height={720}
              loading={i === 0 ? "eager" : "lazy"}
              class="h-full w-full object-contain"
            />
          </div>
        ))}
      </div>
      <div class="swiper-pagination" />
    </div>
  )
}

<script>
  import Swiper from "swiper";
  import { Autoplay, Pagination, Keyboard, A11y } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/pagination";

  // 頁面上每個 .gallery-swiper 各自初始化（支援多個 instance）
  document.querySelectorAll<HTMLElement>(".gallery-swiper").forEach((el) => {
    new Swiper(el, {
      modules: [Autoplay, Pagination, Keyboard, A11y],
      loop: true,
      spaceBetween: 16,
      autoplay: {
        delay: 3000,
        disableOnInteraction: false,
      },
      keyboard: { enabled: true },
      pagination: { el: el.querySelector(".swiper-pagination"), clickable: true },
    });
  });
</script>

<style>
  .gallery-swiper {
    width: 100%;
    aspect-ratio: 3 / 2;
    border-radius: 0.5rem;
    overflow: hidden;
    --swiper-theme-color: rgba(255, 255, 255, 0.8);
    --swiper-pagination-bullet-inactive-color: rgba(255, 255, 255, 1);
  }
</style>
