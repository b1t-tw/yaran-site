---
import { Image } from "astro:assets";
import { loadGalleryItems } from "../lib/gallery";

interface Props {
  /** 相對於 src/assets/images 的資料夾名稱，例如 "plans/misora"、"other" */
  dir: string;
  /** 圖片 alt 前綴 */
  alt?: string;
}

const { dir, alt } = Astro.props;

const slug = dir.replace(/^\/|\/$/g, "");
const items = await loadGalleryItems(dir);
---

{
  items.length > 0 && (
    <div id={`gallery-${slug.replace(/\//g, "-")}`} class="photo-gallery grid grid-cols-2 md:grid-cols-3 gap-4">
      {items.map((item, i) => (
        <a
          href={item.full.src}
          data-pswp-width={item.full.attributes.width}
          data-pswp-height={item.full.attributes.height}
          target="_blank"
          rel="noreferrer"
          class="block overflow-hidden rounded-lg">
          <Image
            src={item.thumb}
            alt={`${alt ?? dir} ${i + 1}`}
            format="webp"
            quality={80}
            width={800}
            height={800}
            loading={i < 3 ? "eager" : "lazy"}
            class="w-full aspect-square object-cover drop-shadow-lg transition duration-300 hover:scale-105"
          />
        </a>
      ))}
    </div>
  )
}

<script>
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import "photoswipe/style.css";

  document.querySelectorAll<HTMLElement>(".photo-gallery").forEach((el) => {
    const lightbox = new PhotoSwipeLightbox({
      gallery: `#${el.id}`,
      children: "a",
      pswpModule: () => import("photoswipe"),
    });
    lightbox.init();
  });
</script>
