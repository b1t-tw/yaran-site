---
import { Image } from "astro:assets";
import { loadGalleryItems } from "../lib/gallery";

interface Props {
  /** 相對於 src/assets/images 的資料夾名稱，例如 "plans/misora"、"other" */
  dir: string;
  /** 圖片 alt 前綴 */
  alt?: string;
  /** 燈箱圖說，依圖片排序對應（可留空跳過某張） */
  captions?: string[];
  objectfit?: string;
}

const { dir, alt, captions, objectfit } = Astro.props;

const slug = dir.replace(/^\/|\/$/g, "");
const items = await loadGalleryItems(dir);
---

{
  items.length > 0 && (
    <div id={`gallery-${slug.replace(/\//g, "-")}`} class="photo-gallery grid grid-cols-2 md:grid-cols-3 gap-4">
      {items.map((item, i) => (
        <a
          href={item.full.src}
          data-pswp-width={item.full.attributes.width}
          data-pswp-height={item.full.attributes.height}
          data-pswp-caption={captions?.[i]}
          target="_blank"
          rel="noreferrer"
          class="block overflow-hidden rounded-lg !opacity-100">
          <Image
            src={item.thumb}
            alt={`${alt ?? dir} ${i + 1}`}
            format="webp"
            quality={80}
            width={800}
            height={800}
            loading={i < 3 ? "eager" : "lazy"}
            class={`w-full aspect-square drop-shadow-lg bg-white transition duration-300 hover:scale-105 ${objectfit ? `object-${objectfit}` : "object-cover"}`}
          />
        </a>
      ))}
    </div>
  )
}

<script>
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import "photoswipe/style.css";
  import { enhanceLightbox } from "../lib/lightbox";

  document.querySelectorAll<HTMLElement>(".photo-gallery").forEach((el) => {
    // 有任一張帶圖說時，照片不滿版：底部留白放圖說
    const hasCaptions = el.querySelector("a[data-pswp-caption]") !== null;

    const lightbox = new PhotoSwipeLightbox({
      gallery: `#${el.id}`,
      children: "a",
      pswpModule: () => import("photoswipe"),
      bgClickAction: "close"
    });
    enhanceLightbox(lightbox, hasCaptions);
    lightbox.init();
  });
</script>
