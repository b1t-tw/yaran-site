---
import Layout from "../../layouts/Layout.astro";
import PlanTabs from "../../components/PlanTabs.astro";
import PhotoGallery from "../../components/PhotoGallery.astro";
import { plans, getPlan } from "../../data/plans";

export function getStaticPaths() {
  return plans.map((plan) => ({ params: { plan: plan.slug } }));
}

const { plan: slug } = Astro.params;
const plan = getPlan(slug!);
if (!plan) return Astro.redirect("/plans");
---

<Layout title={plan.title}>
  {plan.tagline && (
    <div class="mb-8 px-4" slot="subtitle">{plan.tagline}</div>
  )}
  <PlanTabs />
  <main class="pb-8">
    <div class="container">
      <div class="mb-10">
        {plan.intro.map((p) => <p>{p}</p>)}
      </div>

      <div class="mb-6">
        <h2 class="mb-6">✿ 作品集 ✿</h2>
        <PhotoGallery dir={plan.imageDir} alt={plan.title} />
      </div>
    </div>
  </main>
</Layout>
