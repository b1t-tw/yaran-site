---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { plans } from "../../data/plans";
import { loadImages } from "../../lib/gallery";
import { Icon } from "astro-icon/components";
import misora_avatar from "../../assets/misora_avatar.jpg";
import yamamusume_avatar from "../../assets/yamamusume_avatar.jpg";

// 取每個方案資料夾的第一張圖當封面
const covers = await Promise.all(plans.map((plan) => loadImages(`plans/${plan.imageDir}`).then((imgs) => imgs[0])));
const covers_b = await Promise.all(plans.map((plan) => loadImages(`plans/${plan.imageDir}`).then((imgs) => imgs[1])));
---

<Layout title="和服方案">
  <div class="mb-8 container" slot="subtitle">
    <div class="mb-8">
      <p>野蘭攝影棚 x 御空和服 x 藍鵲和洋</p>
      <p>即將開放預約</p>
      <div class="flex items-center justify-center gap-8 my-8">
        <a href="https://www.instagram.com/misora_kimono/" title="御空和服 IG" target="_blank" class="block">
          <Image
            src={misora_avatar}
            format="webp"
            quality={85}
            alt="御空和服"
            width={200}
            class="rounded-full w-24 h-24 object-cover"
          />
        </a>
        <a href="https://www.instagram.com/yamamusume_kimono/" title="藍鵲和洋 IG" target="_blank" class="block">
          <Image
            src={yamamusume_avatar}
            format="webp"
            quality={85}
            alt="藍鵲和洋"
            width={200}
            class="rounded-full w-24 h-24 object-cover"
          />
        </a>
      </div>
    </div>
    <div class="mb-8 grid md:grid-cols-3 gap-8 text-start text-amber-50">
      <div class="border border-[#fff3] rounded-xl p-4 bg-primary/50">
        <h2 class="mb-2 text-amber-100">方案 A │ 滿版小紋和服</h2>
        <div>
          <span class="text-lg">體驗價</span><span class="ms-1 text-4xl text-red-500 font-bold">$6,999</span>
          <span class="opacity-70 whitespace-nowrap"><del>原價 $7,950</del></span>
        </div>
      </div>
      <div class="border border-[#fff3] rounded-xl p-4 bg-primary/50">
        <h2 class="mb-2 text-amber-100">方案 B │ 精緻訪問着</h2>
        <div>
          <span class="text-lg">體驗價</span><span class="ms-1 text-4xl text-red-500 font-bold">$7,500</span>
          <span class="opacity-70 whitespace-nowrap"><del>原價 $8,600</del></span>
        </div>
      </div>
      <div class="border border-[#fff3] rounded-xl p-4 bg-primary/50">
        <h2 class="mb-2 text-amber-100">方案 C │ 和洋折衷</h2>
        <div>
          <span class="text-lg">體驗價</span><span class="ms-1 text-4xl text-red-500 font-bold">$6,888</span>
          <span class="opacity-70 whitespace-nowrap"><del>原價 $7,600</del></span>
        </div>
      </div>
    </div>
    <div class="border border-[#fff3] rounded-xl px-4 py-6 bg-primary/50">
      <div class="grid md:grid-cols-3 gap-8 text-start text-amber-50">
        <div>
          <h3 class="text-amber-50 mb-4 flex items-center"><Icon name="mdi:scissors" class="me-1" />精緻造型</h3>
          <p>包含「完整妝髮設計」與「專業和服着付」，含免費租借和服及配件。</p>
        </div>
        <div>
          <h3 class="text-amber-50 mb-4 flex items-center"><Icon name="mdi:camera" class="me-1" />專業攝影</h3>
          <p>提供 <strong>6</strong> 張精修照片（可依需求加價增修）並全數贈送所有調色毛片。</p>
        </div>
        <div>
          <h3 class="text-amber-50 mb-4 flex items-center"><Icon name="mdi:gift" class="me-1" />專屬紀念</h3>
          <p>贈送一張實體照片，或可選擇體驗獨特的現場藍晒製作，帶走充滿手作溫度的顯影回憶。</p>
        </div>
      </div>
    </div>
  </div>
  <main class="py-8">
    <div class="container">
      <div class="grid gap-x-4 gap-y-8 grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        {
          plans.map((plan, i) => {
            const img = covers[i];
            const img_b = covers_b[i];
            return (
              <a href={`/plans/${plan.slug}`} class="group block no-underline !opacity-100">
                <div class="relative overflow-hidden rounded-lg">
                  {img && (
                    <div class="overflow-hidden relative">
                      <Image
                        src={img}
                        alt={plan.title}
                        format="webp"
                        quality={80}
                        width={500}
                        class="w-full aspect-[2/3] object-cover"
                      />
                      <Image
                        src={img_b}
                        alt={plan.title}
                        format="webp"
                        quality={80}
                        width={500}
                        class="w-full aspect-[2/3] object-cover absolute top-0 left-0 transition-opacity opacity-0 group-hover:opacity-100"
                      />
                    </div>
                  )}
                  <div class="text-xs text-white bg-black/50 w-full text-center z-1 absolute bottom-0 transition md:translate-y-full group-hover:translate-y-0">
                    {plan.type}
                  </div>
                </div>
                <h4 class="mt-4 text-center group-hover:opacity-80 transition">{plan.title}</h4>
              </a>
            );
          })
        }
      </div>
    </div>
  </main>
</Layout>
