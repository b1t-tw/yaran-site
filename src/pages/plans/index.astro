---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { plans } from "../../data/plans";

// 取每個方案資料夾的第一張圖當封面
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/plans/**/*.{jpg,jpeg,png,webp,avif,JPG,JPEG,PNG}",
  { eager: true },
);

const cover = (dir: string) => {
  const prefix = `/src/assets/images/plans/${dir}/`;
  const first = Object.entries(allImages)
    .filter(([path]) => path.startsWith(prefix))
    .sort(([a], [b]) => a.localeCompare(b, undefined, { numeric: true }))[0];
  return first?.[1].default;
};
---

<Layout title="攝影方案">
  <div class="mb-8 px-4" slot="subtitle">佔位副標 — 攝影方案總覽</div>
  <main class="py-8">
    <div class="container">
      <div class="grid gap-8 md:grid-cols-2">
        {
          plans.map((plan) => {
            const img = cover(plan.imageDir);
            return (
              <a href={`/plans/${plan.slug}`} class="group block">
                {img && (
                  <div class="overflow-hidden rounded-lg">
                    <Image
                      src={img}
                      alt={plan.title}
                      format="webp"
                      quality={80}
                      width={1000}
                      height={750}
                      class="w-full aspect-[4/3] object-cover drop-shadow-lg transition duration-300 group-hover:scale-105"
                    />
                  </div>
                )}
                <h2 class="mt-4 text-center group-hover:opacity-80 transition">{plan.title}</h2>
                {plan.tagline && (
                  <p class="text-center text-primary-light mt-1">{plan.tagline}</p>
                )}
              </a>
            );
          })
        }
      </div>
    </div>
  </main>
</Layout>
