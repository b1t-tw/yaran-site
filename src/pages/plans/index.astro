---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { plans } from "../../data/plans";
import { loadImages } from "../../lib/gallery";

// 取每個方案資料夾的第一張圖當封面
const covers = await Promise.all(
  plans.map((plan) => loadImages(`plans/${plan.imageDir}`).then((imgs) => imgs[0])),
);
---

<Layout title="攝影方案">
  <div class="mb-8 px-4" slot="subtitle">佔位副標 — 攝影方案總覽</div>
  <main class="py-8">
    <div class="container">
      <div class="grid gap-8 md:grid-cols-2">
        {
          plans.map((plan, i) => {
            const img = covers[i];
            return (
              <a href={`/plans/${plan.slug}`} class="group block">
                {img && (
                  <div class="overflow-hidden rounded-lg">
                    <Image
                      src={img}
                      alt={plan.title}
                      format="webp"
                      quality={80}
                      width={1000}
                      height={750}
                      class="w-full aspect-[4/3] object-cover drop-shadow-lg transition duration-300 group-hover:scale-105"
                    />
                  </div>
                )}
                <h2 class="mt-4 text-center group-hover:opacity-80 transition">{plan.title}</h2>
                {plan.tagline && (
                  <p class="text-center text-primary-light mt-1">{plan.tagline}</p>
                )}
              </a>
            );
          })
        }
      </div>
    </div>
  </main>
</Layout>
