---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import { Icon } from "astro-icon/components";
import logoH from "../assets/logo_h_gold.png";
import logoV from "../assets/logo_v_gold.png";
import hero1 from "../assets/images/20260515_野蘭空間照_CXL_2164.jpg";
import hero2 from "../assets/images/20260515_野蘭空間照_CXL_2170.jpg";
import hero3 from "../assets/images/20260515_野蘭空間照_CXL_2222.jpg";
import hero4 from "../assets/images/20260515_野蘭空間照_CXL_2301.jpg";
import hero5 from "../assets/images/20260515_野蘭空間照_CXL_2327.jpg";

const heroImages = [hero1, hero2, hero3, hero4, hero5];
---

<Layout title="首頁">
  <div id="hero" class="h-svh w-full flex items-center justify-center relative overflow-hidden">
    <div class="absolute inset-0">
      <div class="swiper hero-swiper">
        <div class="swiper-wrapper">
          {
            heroImages.map((img) => (
              <div class="swiper-slide">
                <Image
                  src={img}
                  alt="Yaran 野蘭攝影棚空間照"
                  format="webp"
                  quality={80}
                  width={2560}
                  class="w-full h-full object-cover object-top"
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
    <div class="absolute inset-0 bg-black/60 z-1"></div>

    <div id="logo" class="w-1/2 fade-up relative z-10 drop-shadow-lg">
      <Image src={logoH} alt="Yaran 野蘭攝影棚" format="webp" quality={85} class="w-full max-md:hidden" />
      <Image src={logoV} alt="Yaran 野蘭攝影棚" format="webp" quality={85} class="w-full md:hidden" />
    </div>

    <div id="scroll-icon" class="absolute bottom-8 left-1/2 transform -translate-x-1/2 scroll-down-icon z-10">
      <div class="flex flex-col items-center">
        <Icon name="ic:baseline-keyboard-arrow-down" class="text-2xl mb-1" />
        <span class="text-sm opacity-70">向下滾動</span>
      </div>
    </div>
    <div class="absolute left-0 right-0 bottom-0 h-20 bg-gradient-to-t from-black/80 to-transparent z-2"></div>
  </div>
  <Header hideLogo={true} />
  <div class="w-full relative">
    <div class="container grid grid-cols-1 md:grid-cols-2 py-20 gap-8">
      <div class="flex flex-col justify-center">
        <h2 class="mb-4">交通方式</h2>
        <div class="grid grid-cols-[1.5rem_1fr] items-center gap-2">
          <Icon name="ic:baseline-directions-railway-filled" /><span>捷運後山埤站4號出口，步行約6分鐘</span>
          <Icon name="ic:baseline-directions-bus" /><span>聯合醫院忠孝院區站，步行約1分鐘</span>
          <Icon name="ic:baseline-directions-car" />
          <span
            ><a target="_blank" href="https://maps.app.goo.gl/gH8bDAB13MsLYKyk7">168 Parking (昆陽一場)</a
            >，步行約3分鐘</span
          >
          <Icon name="ic:baseline-directions-car" />
          <span
            ><a target="_blank" href="https://maps.app.goo.gl/TN6gbewNJ69aQMSA6">俥亭天主堂地下停車場</a
            >，步行約3分鐘</span
          >
        </div>
      </div>
      <div class="drop-shadow-lg min-h-64">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d903.6451365723887!2d121.58371056957773!3d25.048305098612953!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3442ab005f0bb4e7%3A0xc74c815ec0860d48!2zWWFyYW4g6YeO6Jit5pSd5b2x5qOa!5e0!3m2!1szh-TW!2stw!4v1752257053005!5m2!1szh-TW!2stw"
          width="100%"
          height="100%"
          style="border:0; border-radius: 1rem;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Google Map">
        </iframe>
      </div>
    </div>
    <div class="container pb-20">
      <h2 class="mb-4">馬上預約</h2>
      <ul class="list-disc pl-6 mb-2">
        <li>攝影棚為全預約制，若無預約請勿前往。</li>
        <li>開放時間為週一 ~ 週日 9am -10pm，休息日於時間表上公告，非營業時間無法回覆訊息請見諒。</li>
        <li>全區 30 坪無隔間，每次僅接待一組客人，不接受中途換人。</li>
        <li>每次租棚以 2 小時起跳。</li>
      </ul>
      <p>⊱ 試營運優惠價：<strong class="text-4xl"><del>2200</del> 1800 元／小時</strong> ⊰</p>
      <p class="text-sm opacity-70">
        以上費用僅適用於「一般人像／Cosplay、Lolita 攝影」，「商業攝影／婚攝／動態攝影／活動合作」的價格請私訊詢問。
      </p>
      <p class="text-sm opacity-70">商業攝影的定義為用於宣傳、廣告、行銷目的之拍攝。</p>

      <h3 class="mb-4 mt-8">入場人員</h3>
      <ul class="list-disc pl-6 mb-2">
        <li>入場人員最多<strong>總共 5 位，最多 2 位攝影師</strong>（手機不在此限）。</li>
        <li>若有增加人數，每人需酌收 200 元 / 小時，攝影師需酌收 300 元 / 小時 ，但增加後總人數最多 8 人。</li>
        <li>若有 12 歲以下孩童請提前告知。</li>
        <li>目前暫不開放寵物入場。</li>
      </ul>

      <h3 class="mb-4 mt-8">注意事項</h3>
      <ul class="list-disc pl-6 mb-2">
        <li>本棚開放拍攝日<strong> 90 天至一週前預約</strong>（例如：4/1 拍攝日，可於 1/1-3/24 之間預約）。</li>
        <li>
          請於預定後一日內支付訂金 1000 元，<strong>取消、改期請於一週前私訊告知，否則不予退費</strong>（例如：4/1拍攝日，最晚請於 3/24
          營業時間內告知）。
        </li>
        <li>當日遲到、早退、缺席不予退費。</li>
        <li>若遇不可抗力因素（如颱風、地震）且政府公告放假，可改期或全額退訂金。</li>
      </ul>

      <h3 class="mb-4 mt-8">預約方式</h3>
      <ul class="mb-2">
        <li>Step1：確認預約時段，並仔細閱讀攝影棚使用規範後，網站填表預約</li>
        <li>Step2：一日內支付訂金<a href="/prepaid" target="_blank">（線上金流）</a></li>
        <li>Step3：私訊 FB／IG 提供『預約人姓名』、『預約時間』、『電話』</li>
        <li>Step4：確認預約後，小幫手會將官網日曆更新</li>
        <li>Step5：當天入場時繳餘款（可用現金、金流付款）</li>
      </ul>

      <a href="https://frametime.app/v/yaran-studio" target="_blank" class="btn btn-primary mt-6"
        >立即預約 <Icon name="ic:round-menu-book" />
      </a>
    </div>
  </div>
</Layout>

<style>
  .hero-swiper,
  .hero-swiper .swiper-wrapper,
  .hero-swiper .swiper-slide {
    width: 100%;
    height: 100%;
  }
  .fade-up {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 1.5s ease-out,
      transform 1.5s ease-out;
  }
  .fade-up.animate {
    opacity: 1;
    transform: translateY(0);
  }
  .scroll-down-icon {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.8s ease-out,
      transform 0.8s ease-out;
  }
  .scroll-down-icon.show {
    opacity: 1;
    transform: translateY(0);
    animation: bounce 2s infinite;
  }
  @keyframes bounce {
    0%,
    20%,
    50%,
    80%,
    100% {
      transform: translateY(0);
    }
    40% {
      transform: translateY(-10px);
    }
    60% {
      transform: translateY(-5px);
    }
  }
</style>

<script>
  import Swiper from "swiper";
  import { Autoplay, EffectFade } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/effect-fade";

  new Swiper(".hero-swiper", {
    modules: [Autoplay, EffectFade],
    effect: "fade",
    fadeEffect: { crossFade: true },
    loop: true,
    speed: 4000,
    allowTouchMove: false,
    autoplay: {
      delay: 100,
      disableOnInteraction: false,
    },
  });

  const logo = document.getElementById("logo");
  const scrollIcon = document.getElementById("scroll-icon");

  if (logo && scrollIcon) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            logo.classList.add("animate");
            setTimeout(() => scrollIcon.classList.add("show"), 1500);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
    );
    observer.observe(logo);
  }
</script>
